# Prevent npm from looking in parent directories
fund=false
audit=false
# Ensure package-lock.json is only used from this directory
package-lock=true
# Disable problematic npm features
update-notifier=false
# Disable progress bars that might cause issues
progress=false

# pnpm-specific configuration to prevent -4058 errors on Windows
# Use hoisted node linker to avoid symlink issues that cause file system errors
# This reduces the number of symlinks pnpm creates, which helps prevent -4058 errors
node-linker=hoisted
# Store location - use local store to avoid permission issues and reduce symlink depth
store-dir=.pnpm-store
# Reduce concurrent operations to prevent file system lock conflicts
network-concurrency=1
# Disable auto-install-peers to reduce file system operations during install
auto-install-peers=false